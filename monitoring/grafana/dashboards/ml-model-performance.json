        { "expr": "sum(rate(floodingnaque_predictions_total{risk_level=\"alert\"}[5m]))", "legendFormat": "Alert (1)" },
        { "expr": "sum(rate(floodingnaque_predictions_total{risk_level=\"critical\"}[5m]))", "legendFormat": "Critical (2)" }
