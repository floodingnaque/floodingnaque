      "type": "stat",
      "targets": [
        { "expr": "sum(increase(floodingnaque_predictions_total[24h]))", "legendFormat": "Predictions" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
