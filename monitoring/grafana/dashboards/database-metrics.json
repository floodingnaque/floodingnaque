{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Database metrics - connection pools, query latency, replication lag, and backup status for Floodingnaque PostgreSQL",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "🗄️ Connection Pool (PgBouncer)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active Connections",
      "type": "stat",
      "targets": [
        { "expr": "pgbouncer_active_clients", "legendFormat": "Active" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Waiting Connections",
      "type": "stat",
      "targets": [
        { "expr": "pgbouncer_waiting_clients", "legendFormat": "Waiting" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Connection Pool Utilisation",
      "type": "timeseries",
      "targets": [
        { "expr": "pgbouncer_active_clients", "legendFormat": "Active" },
        { "expr": "pgbouncer_idle_clients", "legendFormat": "Idle" },
        { "expr": "pgbouncer_waiting_clients", "legendFormat": "Waiting" },
        { "expr": "pgbouncer_maxwait_seconds", "legendFormat": "Max Wait (s)" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 5,
      "panels": [],
      "title": "⏱️ Query Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "title": "Query Duration Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(floodingnaque_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(floodingnaque_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum(rate(floodingnaque_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(floodingnaque_db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Query Throughput (rate/5m)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(floodingnaque_db_query_duration_seconds_count[5m]))", "legendFormat": "Queries/s" },
        { "expr": "sum(rate(floodingnaque_db_query_errors_total[5m]))", "legendFormat": "Errors/s" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 8,
      "panels": [],
      "title": "💾 Database Size & Backups",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Database Size",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_database_size_bytes{datname=\"floodingnaque\"}", "legendFormat": "Database Size" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 72000 },
              { "color": "red", "value": 90000 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 17 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Time Since Last Backup",
      "type": "stat",
      "targets": [
        { "expr": "time() - floodingnaque_backup_last_success_timestamp_seconds", "legendFormat": "Age" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 17 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Backup Jobs (24h)",
      "type": "timeseries",
      "targets": [
        { "expr": "increase(floodingnaque_backup_success_total[24h])", "legendFormat": "Succeeded" },
        { "expr": "increase(floodingnaque_backup_failure_total[24h])", "legendFormat": "Failed" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 12,
      "panels": [],
      "title": "📋 Table Statistics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Row Count by Table",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_user_tables_n_live_tup{datname=\"floodingnaque\"}", "legendFormat": "{{ relname }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 14,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Dead Tuples (Vacuum Needed)",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_user_tables_n_dead_tup{datname=\"floodingnaque\"}", "legendFormat": "{{ relname }}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["floodingnaque", "database", "postgresql", "pgbouncer"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Floodingnaque - Database Metrics",
  "uid": "floodingnaque-database-metrics",
  "version": 1
}
