# =====================================================
# Floodingnaque Frontend .gitignore
# =====================================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
*.local
.env
.env.*
!.env.example

# Test / coverage artifacts
coverage/
playwright-report/
test-results/
.eslintcache

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Vercel
.vercel/
