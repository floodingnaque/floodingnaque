{
  "name": "frontend",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "type-check": "tsc --noEmit",
    "build:analyze": "cross-env VITE_ANALYZE=true vite build",
    "perf:lighthouse": "lhci autorun",
    "perf:treemap": "npx vite-bundle-visualizer",
    "perf:unused": "npx depcheck",
    "perf:all": "npm run build && npm run perf:lighthouse",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "dependencies": {
