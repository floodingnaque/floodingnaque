.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/


# ===================
# Project Artifacts
# ===================

# ML models & metadata (tracked selectively via Git LFS or reproduced)
models/*.joblib
backend/models/*.joblib
models/confusion_matrix.png
models/feature_importance.png

# Test model files (generated by tests)
test_model.joblib
test_model.json
backend/test_model.joblib
backend/test_model.json

# Data files
data/*.csv
data/earthengine_cache/
backend/data/earthengine_cache/
backend/data/meteostat_cache/

# Generated reports
backend/reports/
!backend/reports/README.md

# Evaluation results
evaluation_results/

# Static files (generated)
backend/static/

# Screenshots / generated images
landing-page-full.png
resident-dashboard-current.png

# Database backups (keep directory, exclude backup files)
backend/backups/*.backup.*
backend/backups/*.sql
backend/backups/*.sql.gz
backend/backups/*.gz
*.db.backup.*


