# =====================================================
# Docker Ignore File for Floodingnaque Backend
# =====================================================
# Prevents unnecessary files from being copied to Docker image

# Git
.git/
.gitignore
.gitattributes

# Python bytecode & packaging
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# Environment files (use env_file directive or --env-file at runtime)
.env
.env.*
!.env.example

# Sensitive files - SECURITY
*.pem
*.key
*.p12
*.pfx
secrets/
secrets*
*.secret
credentials/
.credentials

# Keep certs directory structure (files are mounted at runtime)
!certs/
!certs/.gitkeep

# Google Cloud credentials (NEVER include in Docker image!)
google_oauth_credentials.json
google_application_credentials*.json
client_secret*.json
*-service-account.json
*-sa-key.json
floodingnaque-*.json
*.iam.gserviceaccount.com.json
earth*.json
astral-archive-*.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Testing
.tox/
.nox/
.coverage
.coverage.*
.coveragerc
htmlcov/
.pytest_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
pytest.ini
mypy.ini
tests/

# Documentation (not needed in runtime)
docs/
*.md
!README.md

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs (created at runtime)
logs/
*.log

# Temp files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db

# Scripts not needed in production
scripts/
!scripts/backup_database.sh
!scripts/backup_database.py
!scripts/purge_expired_ips.py

# Evaluation results
evaluation_results/

# Backups
backups/
*.bak

# Database files
*.db
data/*.db

# Data subdirectories (raw/cleaned data not needed — mounted at runtime)
data/raw/
data/cleaned/
data/processed/
data/earthengine_cache/
data/meteostat_cache/

# Reports
reports/

# mypy cache
.mypy_cache/

# Docker files (prevent nested copying)
Dockerfile*
docker-compose*
compose.*
.dockerignore

# Misc tooling
.flake8
.pre-commit-config.yaml
.cache_ggshield
.ggshield.yaml
.ggshield/
