# =====================================================
# FLOODINGNAQUE BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================================
#
# USAGE:
#   1. Copy this file to .env.development, .env.staging, or .env.production
#   2. Set APP_ENV to select which file to load:
#      - APP_ENV=development -> loads .env.development
#      - APP_ENV=staging     -> loads .env.staging
#      - APP_ENV=production  -> loads .env.production
#   3. Fill in your environment-specific values
#
# QUICK START (Development):
#   1. cp .env.example .env.development
#   2. Set AUTH_BYPASS_ENABLED=True for local testing without API keys
#   3. Or set VALID_API_KEYS=test-key-1,test-key-2 for API key testing
#   4. Ensure CORS_ORIGINS includes http://localhost:3000 for Vite frontend
#   5. For SQLite dev database: DATABASE_URL=sqlite:///data/floodingnaque.db
#
# SECURITY:
#   - NEVER commit real API keys or secrets to git
#   - Use separate keys for each environment
#   - Rotate keys immediately if exposed
#

# ====================
# APP Environment
# ====================
APP_ENV=development
FLASK_DEBUG=True
ENABLE_HTTPS=False

# ====================
# Server Configuration
# ====================
PORT=5000
HOST=0.0.0.0

# ====================
# Security Settings
# ====================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_random_secret_key_in_production
JWT_SECRET_KEY=change_this_to_another_random_secret_key

# API Key Authentication
# Generate secure keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# For development testing, you can use simple keys like: dev-api-key-1,dev-api-key-2
VALID_API_KEYS=your_api_key_1,your_api_key_2

# Enable auth bypass in development (NEVER in production!)
# Set to True to skip API key validation during local development
# When True, all requests are authenticated without requiring X-API-Key header
AUTH_BYPASS_ENABLED=False

# API Key Security
# Minimum entropy (randomness) required for API keys (bits per character)
API_KEY_MIN_ENTROPY=3.0
# Default expiration for API keys (0 = no expiration)
API_KEY_DEFAULT_EXPIRY_DAYS=0

# Brute Force Protection
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_ATTEMPT_WINDOW=300
AUTH_LOCKOUT_DURATION=900

# Request Size Limits (in MB)
MAX_CONTENT_LENGTH_MB=16

# Model Integrity and Security
VERIFY_MODEL_INTEGRITY=True
REQUIRE_MODEL_SIGNATURE=False
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MODEL_SIGNING_KEY=

# ====================
# Database Configuration
# ====================
# SQLite (default for development)
# DATABASE_URL=sqlite:///data/floodingnaque.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/floodingnaque

# Supabase PostgreSQL (RECOMMENDED - cloud hosted)
# Get your connection string from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_key_here
# Connection string format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# ====================
# Database SSL Configuration
# ====================
# SSL Mode Options:
#   - require (default for development): Encrypted connection, no certificate verification
#   - verify-ca: Encrypted + verify CA certificate
#   - verify-full (default for production/staging): Encrypted + verify CA + hostname check
#
# Environment defaults (if DB_SSL_MODE not set):
#   - Development: require (no certificate needed)
#   - Staging/Production: verify-full (certificate required, fail-fast if missing)
#
# For verify-ca or verify-full, you MUST set DB_SSL_CA_CERT to the CA certificate path
# The certificate file is included at: ./certs/prod-ca-2021.crt (Supabase Root CA)
DB_SSL_MODE=require
DB_SSL_CA_CERT=./certs/prod-ca-2021.crt

# ====================
# Connection Pool Settings
# ====================
# Connection Pool Settings:
# - Supabase Free: pool_size=3, max_overflow=5
# - Supabase Pro: pool_size=20, max_overflow=10
# - Self-hosted: pool_size=20-50 based on resources
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=True
DB_ECHO_POOL=False

# ====================
# PgBouncer Connection Pooler
# ====================
# Enable PgBouncer for connection pooling (recommended for production)
USE_PGBOUNCER=False
PGBOUNCER_URL=postgresql://postgres:password@pgbouncer:6432/floodingnaque

# PgBouncer Pool Settings
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_MIN_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_MAX_DB_CONNECTIONS=50

# PgBouncer Database Connection
PGBOUNCER_DB_HOST=your-db-host.example.com
PGBOUNCER_DB_PORT=5432
PGBOUNCER_DB_NAME=postgres
PGBOUNCER_DB_USER=your_db_user
PGBOUNCER_DB_PASSWORD=

# PgBouncer Admin (for monitoring)
PGBOUNCER_ADMIN_USER=pgbouncer_admin
PGBOUNCER_ADMIN_PASSWORD=change_this_password
PGBOUNCER_STATS_USER=pgbouncer_stats
PGBOUNCER_STATS_PASSWORD=change_this_password

# ====================
# Read Replica Configuration
# ====================
# Enable read replica for dashboard/analytics queries
READ_REPLICA_ENABLED=False
DATABASE_REPLICA_URL=postgresql://postgres:password@replica-db.example.com:5432/floodingnaque
READ_REPLICA_LAG_THRESHOLD_MS=100

# ====================
# Time-Series Partitioning
# ====================
# Enable time-series partitioning for historical data (PostgreSQL 11+)
TIME_SERIES_PARTITIONING_ENABLED=True
PARTITION_INTERVAL=monthly
PARTITION_RETENTION_MONTHS=24
PARTITION_FUTURE_MONTHS=3
PARTITION_AUTO_CREATE=True

# ====================
# Redis Configuration
# ====================
# Main Redis instance
# Format: redis://[[username]:[password]]@localhost:6379/0
# TLS Format: rediss://[[username]:[password]]@host:6380/0
REDIS_URL=
REDIS_PASSWORD=changeme

# ====================
# Caching Configuration
# ====================
CACHE_ENABLED=False
CACHE_TYPE=simple
CACHE_REDIS_URL=
CACHE_DEFAULT_TIMEOUT=300

# ====================
# Celery Configuration (Background Tasks)
# ====================
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_WORKERS=2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Manila
CELERY_ENABLE_UTC=True

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW_SECONDS=3600
# Use redis:// for production (recommended), memory:// for development
RATE_LIMIT_STORAGE_URL=memory://
RATELIMIT_STORAGE_URL=memory://

# Burst Allowance Configuration
RATE_LIMIT_BURST_ENABLED=True
RATE_LIMIT_BURST_MULTIPLIER=2.0
RATE_LIMIT_BURST_WINDOW=10

# Internal Service Rate Limit Bypass
RATE_LIMIT_INTERNAL_BYPASS_ENABLED=True
RATE_LIMIT_INTERNAL_BYPASS_IPS=127.0.0.1,::1

# IP Reputation System for Rate Limiting
IP_WHITELIST=
IP_BLACKLIST=

# API Key Tier Mapping
# Format: key_hash1:tier1,key_hash2:tier2
API_KEY_TIERS=

# Slow Query Logging
SLOW_QUERY_THRESHOLD_MS=100

# Response Time Tracking
RESPONSE_TIME_TRACKING_ENABLED=True

# Query Cache Settings
DATA_CACHE_TTL=60
PREDICTION_CACHE_TTL=300
PREDICTION_CACHE_ENABLED=True

# ====================
# CORS Configuration
# ====================
# Development: Include Vite dev server (localhost:3000) and backend (localhost:5000)
# Production: Replace with your production frontend URL(s)
# Example production: CORS_ORIGINS=https://floodingnaque.vercel.app,https://www.floodingnaque.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID,X-CSRF-Token,Accept,Origin

# ====================
# Gunicorn Configuration
# ====================
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_WORKER_CLASS=sync
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# ====================
# API Keys (External Services)
# ====================
# OpenWeatherMap - Get from: https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here
OWM_UNITS=metric
OWM_LANG=en

# WeatherStack - Get from: https://weatherstack.com/
WEATHERSTACK_API_KEY=your_weatherstack_api_key_here

# Internal API auth token for microservices
INTERNAL_API_TOKEN=your_internal_api_token_here

# ====================
# Alert System Configuration
# ====================
# SMS Gateway - Using Semaphore (Philippines)
# In production: SMS_ENABLED=True, SMS_SANDBOX_MODE=False
# Critical risk alerts auto-trigger SMS regardless of alert_type
SMS_ENABLED=False
SMS_SANDBOX_MODE=True
SMS_PROVIDER=semaphore

# Semaphore SMS (Philippines - Affordable) - https://semaphore.co/
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=FloodAlert

# Twilio SMS (International) - https://twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ====================
# PAGASA Radar Integration
# ====================
# Radar-based precipitation estimates from PAGASA Doppler radar network
# Provides per-barangay rainfall detection for Parañaque City
PAGASA_RADAR_ENABLED=True
PAGASA_API_URL=https://api.pagasa.dost.gov.ph
PAGASA_API_KEY=
PAGASA_RADAR_CACHE_TTL=300
PAGASA_TIMEOUT=15

# Email Configuration (SMTP)
EMAIL_ENABLED=False
EMAIL_SANDBOX_MODE=True
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True

# Brevo API Key (for API-based email if needed)
BREVO_API_KEY=

# ====================
# Webhooks Configuration
# ====================
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# ====================
# Batch Processing Configuration
# ====================
BATCH_SIZE=100
BATCH_TIMEOUT_SECONDS=300
BATCH_MAX_WORKERS=4

# ====================
# GraphQL Configuration
# ====================
GRAPHQL_ENABLED=true
GRAPHQL_PLAYGROUND_ENABLED=True
GRAPHQL_INTROSPECTION_ENABLED=True

# ====================
# Logging Configuration
# ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (default), ecs (Elastic Common Schema), text (human-readable)
LOG_FORMAT=json

# Enable ANSI colors for text format (development only)
LOG_COLORS=true

# Log directory
LOG_DIR=logs

# Log file settings
LOG_FILE=logs/floodingnaque.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=30
LOG_COMPRESS=True

# Log Sampling (for high-volume production environments)
LOG_SAMPLING_ENABLED=false
LOG_SAMPLING_RATE=0.1
LOG_SAMPLING_EXCLUDE_ERRORS=true

# ====================
# Parañaque City Default Coordinates
# ====================
DEFAULT_LATITUDE=14.4793
DEFAULT_LONGITUDE=121.0198
DEFAULT_LOCATION=Parañaque City

# ====================
# Model Configuration
# ====================
MODEL_DIR=models
MODEL_NAME=flood_rf_model
MODEL_VERSION=1.0
MODEL_RETRAIN_CRON=0 0 * * *
AUTO_RETRAIN=False
RETRAIN_INTERVAL_DAYS=30

# Training Resource Allocation
TRAINING_N_JOBS=

# ====================
# Data Retention
# ====================
WEATHER_DATA_RETENTION_DAYS=365
PREDICTION_DATA_RETENTION_DAYS=180
ALERT_HISTORY_RETENTION_DAYS=90

# ====================
# Scheduler Configuration
# ====================
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=Asia/Manila
DATA_INGEST_INTERVAL_HOURS=1
MODEL_EVALUATION_INTERVAL_DAYS=7
DATABASE_CLEANUP_INTERVAL_DAYS=1

# ====================
# Data Directory Pointers
# ====================
DATA_DIR=data
LOGS_DIR=logs
UPLOADS_DIR=uploads
TEMP_DIR=temp
BACKUP_DIR=backups

# ====================
# Security Headers
# ====================
# HTTPS/HSTS Settings
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=True
HSTS_PRELOAD=False

# Cross-Origin Policies
COEP_POLICY=unsafe-none
COOP_POLICY=same-origin-allow-popups
CORP_POLICY=cross-origin

# Content Security Policy
# CSP_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'

# CSP Reporting
CSP_REPORT_URI=/csp-report
CSP_REPORT_LOG_FILE=logs/csp_violations.log

# ====================
# Security.txt Configuration (RFC 9116)
# ====================
SECURITY_CONTACT_EMAIL=security@floodingnaque.com
SECURITY_POLICY_URL=https://floodingnaque.com/security-policy
SECURITY_ACKNOWLEDGMENTS_URL=https://floodingnaque.com/security/thanks
SECURITY_CANONICAL_URL=https://api.floodingnaque.com/.well-known/security.txt
SECURITY_TXT_EXPIRES=2028-12-31T23:59:59Z

# ====================
# Encryption Settings
# ====================
ENCRYPTION_ENABLED=True
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=generate_a_64_character_hex_key_using_secrets_module
ENCRYPTION_ALGORITHM=AES-256-GCM
TOKEN_ENCRYPTION_KEY=generate_another_64_character_hex_key_using_secrets_module
TOKEN_EXPIRY_HOURS=24

# ====================
# IP Whitelist (Admin Dashboard)
# ====================
IP_WHITELIST_ENABLED=True
ADMIN_ALLOWED_IPS=127.0.0.1,::1
ADMIN_DASHBOARD_ENABLED=True
ADMIN_REQUIRE_2FA=True

# ====================
# Feature Toggles
# ====================
FEATURE_PREDICTIONS_ENABLED=True
FEATURE_ALERTS_ENABLED=True
FEATURE_HISTORICAL_DATA_ENABLED=True
FEATURE_REAL_TIME_WEATHER_ENABLED=True
FEATURE_MODEL_RETRAINING_ENABLED=False
FEATURE_API_DOCS_ENABLED=True
FEATURE_ADMIN_DASHBOARD_ENABLED=True
FEATURE_EXPORT_DATA_ENABLED=True
FEATURE_SCHEDULER_ENABLED=True
FEATURE_METRICS_ENABLED=True

# ====================
# Feature Flags System
# ====================
# Model Rollout Flags
FEATURE_FLAG_MODEL_V2_ROLLOUT=0
FEATURE_FLAG_MODEL_V2_FULL_RELEASE=disabled

# Emergency API Bypass Flags
FEATURE_FLAG_BYPASS_ALL_EXTERNAL_APIS=disabled
FEATURE_FLAG_BYPASS_OPENWEATHERMAP=disabled
FEATURE_FLAG_BYPASS_WEATHERSTACK=disabled
FEATURE_FLAG_BYPASS_WORLDTIDES=disabled

# A/B Testing Flags
FEATURE_FLAG_ALERT_THRESHOLD_EXPERIMENT=enabled

# Feature Flags for New Features
FEATURE_FLAG_ENHANCED_PREDICTIONS=0
FEATURE_SATELLITE_DATA_ENABLED=False
FEATURE_REALTIME_ALERTS_ENABLED=True

# Admin API Keys (comma-separated)
ADMIN_API_KEYS=

# ====================
# Observability & Monitoring
# ====================
# Prometheus metrics endpoint: /metrics
PROMETHEUS_METRICS_ENABLED=true

# Service metadata for distributed tracing
SERVICE_NAME=floodingnaque-api
APP_VERSION=2.0.0

# ====================
# Observability & Telemetry
# ====================
TELEMETRY_ENABLED=True
APM_SERVICE_NAME=floodingnaque-backend
APM_ENVIRONMENT=production

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_ENABLED=False
OTEL_METRICS_ENABLED=False
OTEL_LOGS_ENABLED=False

# ====================
# Sentry Error Tracking
# ====================
# Get DSN from: Project Settings > Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=2.0.0

# Performance Monitoring
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ====================
# Prometheus Metrics
# ====================
METRICS_ENABLED=False
METRICS_PORT=9090
METRICS_PATH=/metrics

# ====================
# Health Check Configuration
# ====================
HEALTH_CHECK_INCLUDE_DETAILS=True
HEALTH_CHECK_DB_TIMEOUT_SECONDS=5
HEALTH_CHECK_RESPONSE_TIME_SLA_MS=1000

# ====================
# Environment Validation
# ====================
ENV_VALIDATION_ENABLED=False

# ====================
# Google Cloud / Earth Engine Configuration
# ====================
# Project ID from Google Cloud Console
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# OAuth 2.0 Client (for user-facing auth)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Service Account (for server-to-server auth - RECOMMENDED)
# SECURITY: Store the JSON key content as base64, NOT as a file path in the repo
# Generate: cat service-account.json | base64 -w 0
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Alternative: Path to service account JSON file (store in certs/ directory)
GOOGLE_APPLICATION_CREDENTIALS=./certs/floodingnaque-service-account.json

# Service Account Email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-gcp-project-id.iam.gserviceaccount.com

# Earth Engine Settings
EARTHENGINE_ENABLED=True
EARTHENGINE_PROJECT=your-gcp-project-id
EARTHENGINE_CACHE_DIR=data/earthengine_cache

# BigQuery Settings (for historical weather data)
BIGQUERY_ENABLED=True
BIGQUERY_DATASET=weather_data

# Data Sources Toggle
GPM_PRECIPITATION_ENABLED=True
CHIRPS_PRECIPITATION_ENABLED=True
ERA5_REANALYSIS_ENABLED=True

# ====================
# WorldTides API Configuration
# ====================
# Get your API key from: https://www.worldtides.info/settings
WORLDTIDES_API_KEY=your_worldtides_api_key_here
WORLDTIDES_ENABLED=True
WORLDTIDES_DATUM=MSL
WORLDTIDES_CACHE_TTL_SECONDS=1800

# ====================
# Required for Docker Compose Configuration
# ====================
# NOTE: These are standard dotenv key=value pairs (compatible with
# python-dotenv and docker compose).  Do NOT use PowerShell syntax
# ($env:VAR = "value") here — it breaks python-dotenv parsing.
POSTGRES_PASSWORD=your_secure_password
REDIS_PASSWORD=your_redis_password
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password

# ====================
# MLFlow Configuration
# ====================
MLFLOW_DB_PASSWORD=your_mlflow_password

# ====================
# Alertmanager Configuration
# ====================
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_FROM=alerts@floodingnaque.com
ALERTMANAGER_SMTP_USER=your_email
ALERTMANAGER_SMTP_PASSWORD=your_app_password
ALERTMANAGER_NOTIFY_EMAIL=team@floodingnaque.com

# ============================================================================
# WEB PUSH NOTIFICATIONS (VAPID)
# ============================================================================
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_EMAIL=mailto:drrmo@paranaque.gov.ph

# ============================================================================
# NGROK TUNNEL (Development Only)
# ============================================================================
# Expose the local API to the internet for webhook testing and mobile previews.
# Install: pip install -r requirements-dev.txt
# Get auth token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_ENABLED=False
NGROK_AUTHTOKEN=
# Optional: reserve a static domain on https://dashboard.ngrok.com/domains
NGROK_DOMAIN=
# Tunnel region: us, eu, ap, au, sa, jp, in
NGROK_REGION=
